            do Screen.drawLine(x+21, y+25, x+22, y+22);

            do Screen.drawLine(x+22, y+21, x+22, y+22);
            do Screen.drawLine(x+22, y+23, x+22, y+22);
            return;
        }

        if ((slovo = 67) | (slovo = 99)) {  // C/c
            do Screen.drawLine(x+23, y+6, x+15, y+6);
            do Screen.drawLine(x+23, y+29, x+15, y+29);
            do Screen.drawLine(x+23, y+7, x+15, y+7);
            do Screen.drawLine(x+23, y+28, x+15, y+28);

            do Screen.drawLine(x+15, y+6, x+10, y+9);
            do Screen.drawLine(x+15, y+29, x+10, y+26);
            do Screen.drawLine(x+15, y+7, x+10, y+10);
            do Screen.drawLine(x+15, y+28, x+10, y+25);

            do Screen.drawLine(x+10, y+9, x+7, y+14);
