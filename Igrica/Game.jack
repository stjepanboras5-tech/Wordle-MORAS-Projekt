            do Screen.drawLine(x+10, y+26, x+7, y+21);
            do Screen.drawLine(x+10, y+25, x+6, y+20);

            do Screen.drawLine(x+14, y+29, x+19, y+26);
            do Screen.drawLine(x+14, y+28, x+19, y+25);
            do Screen.drawLine(x+19, y+26, x+23, y+20);

            do Screen.drawLine(x+12, y+28, x+17, y+28);
            return;
        }

        if ((slovo = 75) | (slovo = 107)) { // K/k
            do Screen.drawLine(x+6, y+6, x+6, y+29);
            do Screen.drawLine(x+7, y+6, x+7, y+29);

            do Screen.drawLine(x+6, y+17, x+23, y+6);
            do Screen.drawLine(x+7, y+16, x+22, y+6);
            do Screen.drawLine(x+6, y+18, x+23, y+6);

