        }

        if ((slovo = 77) | (slovo = 109)) { // M/m
            do Screen.drawLine(x+6, y+6, x+6, y+29);
            do Screen.drawLine(x+7, y+6, x+7, y+29);
            do Screen.drawLine(x+23, y+6, x+23, y+29);
