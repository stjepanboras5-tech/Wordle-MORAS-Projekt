class Game {
    field String rijec;
    field int pokusaj;
    field int duljina_rijeci;
    field int pocetni_x;
    field int last_3word, last_4word, last_5word; 
    static bool weak_izlaz;
    static int seed;

    constructor Game new() {
        let seed = 0;
        let last_3word = 300;
        let last_4word = 300;
        let last_5word = 300;
        return this;
    }

    method void run() {
        var int x, y, i, j, slovo, pozicija, timer;
        var String pogadaj;
        var bool boja_timera, gotovo;

        while (true) {  // MAIN FUNKCIJA IGRICE
            do Screen.clearScreen();
            let slovo = 0;
            let pokusaj = 0;
            let weak_izlaz = false;
            let gotovo = false;

            do pocetni_screen();
            let duljina_rijeci = 3;
            let x = 42;
            let y = 140;
            do Sys.wait(400);

            while (~(slovo = 128)) {  // POCETNI SCREEN - BIRANJE DULJINE RIJECI
                let slovo = 0;
                while (slovo = 0) {
                    let slovo = Keyboard.keyPressed();
                    if (seed = 32767) { let seed = -1; }
                    let seed = seed + 1;
                }
                if ((slovo = 130) | (slovo = 65) | (slovo = 97)) {  // <-
                    do crtaj(duljina_rijeci+48, false, false, x, y, false);
                    if (duljina_rijeci = 3) {
                        let x = 442;
                        let duljina_rijeci = 5;
                        do crtaj(duljina_rijeci+48, false, false, x, y, true);
                    }
                    else {
                        let x = x - 200;
                        let duljina_rijeci = duljina_rijeci - 1;
                        do crtaj(duljina_rijeci+48, false, false, x, y, true);
                    }
                }
                if ((slovo = 132) | (slovo = 68) | (slovo = 100)) {  // ->
                    do crtaj(duljina_rijeci+48, false, false, x, y, false);
                    if (duljina_rijeci = 5) {
                        let x = 42;
                        let duljina_rijeci = 3;
                        do crtaj(duljina_rijeci+48, false, false, x, y, true);
                    }
                    else {
                        let x = x + 200;
                        let duljina_rijeci = duljina_rijeci + 1;
                        do crtaj(duljina_rijeci+48, false, false, x, y, true);
                    }
                }
                if ((slovo > 50) & (slovo < 54)) {  // 3,4,5
                    do crtaj(duljina_rijeci+48, false, false, x, y, false);
                    let x = 42 + Math.multiply(200, slovo-51);
                    let duljina_rijeci = slovo - 48;
                    do crtaj(duljina_rijeci+48, false, false, x, y, true);
                }
                if (slovo = 140) {
                    return;
                }
                do Sys.wait(175);
            }
            do Screen.clearScreen();

            let pocetni_x = Math.divide(516 - Math.multiply(duljina_rijeci, 34), 2)  + 1;
            do odabir_rijeci();

            let y = 0 - 44;
            let i = 0;
            while (i < 6) {           // CRTANJE KUCICA
                let x = pocetni_x;
                let y = y + 44;
                let j = 0;
                while (j < duljina_rijeci) {
                    do crtaj(0, false, false, x, y, true);
                    let x = x + 34;
                    let j = j + 1;
                }
                let i = i + 1;
            }

            let y = 0 - 44;
            let timer = 0;
            let boja_timera = true;
            while ((pokusaj < 6) & (weak_izlaz = false) & (gotovo = false))  {      // MAIN POKUSAJI
                let x = pocetni_x;
                let y = y + 44;
                let slovo = 0;
                let pozicija = 0;
                let pogadaj = String.new(duljina_rijeci);
                while (((pozicija < duljina_rijeci) | (~(slovo = 128))) & (weak_izlaz = false)) {
                    if (slovo = Keyboard.keyPressed()) {
                        do Sys.wait(70);
                    }
                    let slovo = 0;
                    while (slovo = 0) {
                        let slovo = Keyboard.keyPressed();
                        if ((timer > 2500) & (pozicija < duljina_rijeci)) {
                            if (boja_timera = true) {
                                do crtaj(95, false, false, x, y, true);
                            }
                            else {
                                do crtaj(0, false, false, x, y, true);
                            }
                            let timer = -1;
                            let boja_timera = ~boja_timera;
                        }
                        let timer = timer + 1;
                    }
                    if ((((slovo > 64) & (slovo < 91)) | ((slovo > 96) & (slovo < 123))) & (pozicija < duljina_rijeci)) {
                        do crtaj(slovo, false, false, x, y, true);
                        let x = x + 34;
                        let pozicija = pozicija + 1;
                        if ((slovo > 96) & (slovo < 123)) {
                            let slovo = slovo - 32;
                            do pogadaj.appendChar(slovo);
                            let slovo = slovo + 32;
                        }
                        else {
                            do pogadaj.appendChar(slovo);
                        }
                    }
                    if ((slovo = 129) & (pozicija > 0)) {
                        if (pozicija < duljina_rijeci) {
                            do crtaj(0, false, false, x, y, true);
                        }
                        let x = x - 34;
                        let pozicija = pozicija - 1;
                        do crtaj(0, false, false, x, y, true);
                        do pogadaj.eraseLastChar();
                    }
                    if (slovo = 140) {
                        let weak_izlaz = true;
                        do pogadaj.dispose();
                    }
                    do Sys.wait(40);
                }
                
                if (weak_izlaz = false) {  // PROVJERA POKUSAJA
                    let gotovo = provjera(pogadaj, pokusaj);
                    do pogadaj.dispose();
                    let pokusaj = pokusaj + 1;
                }
            }

            if (weak_izlaz = false) {  // RUNDA GOTOVA
                do Sys.wait(150);
                let slovo = 0;
                while (slovo = 0) { let slovo = Keyboard.keyPressed(); }
                do Screen.clearScreen();
                do zavrsni_screen(gotovo);
                let slovo = 0;
                while (slovo = 0) { let slovo = Keyboard.keyPressed(); }
            }
        }
        return;
    }

