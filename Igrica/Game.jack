            do Screen.drawLine(x+22, y+15, x+22, y+18);
            do Screen.drawLine(x+22, y+20, x+22, y+17);
            return;
        }

        if ((slovo = 69) | (slovo = 101)) { // E/e
            do Screen.drawLine(x+6, y+6, x+6, y+29);
            do Screen.drawLine(x+7, y+6, x+7, y+29);
            do Screen.drawLine(x+6, y+6, x+23, y+6);
            do Screen.drawLine(x+6, y+7, x+23, y+7);
