    method bool provjera(String pogadaj, int pokusaj) {
        var int i, j, x, y, broj_tocnih;
        var String temp_rijec;
        let broj_tocnih = 0;

        let i = 0;
        let temp_rijec = String.new(duljina_rijeci);
        while (i < duljina_rijeci) {
            do temp_rijec.appendChar(rijec.charAt(i));
            let i = i + 1;
        }

        let i = 0;
        let x = pocetni_x;
        let y = pokusaj * 44;
        while (i < duljina_rijeci) {
            if (temp_rijec.charAt(i) = pogadaj.charAt(i)) {
                do crtaj(pogadaj.charAt(i), true, false, x, y, true);
                do temp_rijec.setCharAt(i, 95);
                do pogadaj.setCharAt(i, 95);
                let broj_tocnih = broj_tocnih + 1;
            }
            let x = x + 34;
            let i = i + 1;
        }

        let i = 0;
        let x = pocetni_x;
        while (i < duljina_rijeci) {
            let j = 0;
            if (~(pogadaj.charAt(i) = 95)) {
                while (j < duljina_rijeci) {
                    if (temp_rijec.charAt(j) = pogadaj.charAt(i)) {
                        do crtaj(pogadaj.charAt(i), false, true, x, y, true);
                        do temp_rijec.setCharAt(j, 95);
                        do pogadaj.setCharAt(i, 95);
                        let j = duljina_rijeci;
                    }
                    let j = j + 1;
                }
            }
            let x = x + 34;
            let i = i + 1;
        }

        do temp_rijec.dispose();

        if (broj_tocnih = duljina_rijeci) { return true; }
        else { return false; }
    }

