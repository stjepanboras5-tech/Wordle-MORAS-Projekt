        let x = x + 200;
        do crtaj(53, false, false, x, y, false);

        return;
    }

    method void zavrsni_screen(bool pobjeda) {
        var int x, y, i;
        if (pobjeda = true) {
            let x = 171;
            let y = 111;

            do Screen.setColor(true);
            do Screen.drawRectangle(x-7, y-7, x+182, y+42);
            do Screen.setColor(false);
            do Screen.drawRectangle(x-5, y-5, x+180, y+40);
            do Screen.setColor(true);

            do crtaj(121, false, false, x, y, false);
            let x = x + 24;
            do crtaj(111, false, false, x, y, false);
            let x = x + 24;
            do crtaj(117, false, false, x, y, false);
            let x = x + 24;
            do crtaj(0, false, false, x, y, false);
            let x = x + 24;
            do crtaj(119, false, false, x, y, false);
            let x = x + 24;
            do crtaj(105, false, false, x, y, false);
            let x = x + 24;
            do crtaj(110, false, false, x, y, false);
        }
        else {
            let x = 159;
            let y = 111;

            do Screen.setColor(true);
            do Screen.drawRectangle(x-7, y-7, x+206, y+42);
            do Screen.setColor(false);
            do Screen.drawRectangle(x-5, y-5, x+204, y+40);
            do Screen.setColor(true);

            do crtaj(121, false, false, x, y, false);
            let x = x + 24;
            do crtaj(111, false, false, x, y, false);
            let x = x + 24;
            do crtaj(117, false, false, x, y, false);
            let x = x + 24;
            do crtaj(0, false, false, x, y, false);
            let x = x + 24;
            do crtaj(108, false, false, x, y, false);
            let x = x + 24;
            do crtaj(111, false, false, x, y, false);
            let x = x + 24;
            do crtaj(115, false, false, x, y, false);
            let x = x + 24;
            do crtaj(101, false, false, x, y, false);

            do Sys.wait(200);
            let i = 0;
            while (i = 0) { let i = Keyboard.keyPressed(); }
            do Screen.clearScreen();
    
            let x = 112;
            let y = 83;
            do crtaj(116, false, false, x, y, false);
            let x = x + 24;
            do crtaj(104, false, false, x, y, false);
            let x = x + 24;
            do crtaj(101, false, false, x, y, false);
            let x = x + 24;
    
            do crtaj(0, false, false, x, y, false);
            let x = x + 24;
    
            do crtaj(119, false, false, x, y, false);
            let x = x + 24;
            do crtaj(111, false, false, x, y, false);
            let x = x + 24;
            do crtaj(114, false, false, x, y, false);
            let x = x + 24;
            do crtaj(100, false, false, x, y, false);
            let x = x + 24;
    
            do crtaj(0, false, false, x, y, false);
            let x = x + 24;
    
            do crtaj(119, false, false, x, y, false);
            let x = x + 24;
            do crtaj(97, false, false, x, y, false);
            let x = x + 24;
            do crtaj(115, false, false, x, y, false);
    
            let x = Math.divide(516 - Math.multiply(duljina_rijeci,24), 2) - 3 - 24;
            let y = y + 46;
            let i = 0;
            while (i < duljina_rijeci) {
                let x = x + 24;
                do crtaj(rijec.charAt(i), false, false, x, y, false);
                let i = i + 1;
            }
        }

        do Sys.wait(600);
        return;
    }

    method void dispose() {
        do Memory.deAlloc(this);
        return;
    }
