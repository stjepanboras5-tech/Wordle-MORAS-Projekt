    method void crtaj(int slovo, bool pogodio, bool narancasto, int x, int y, bool kucica) {
        if (kucica = true) {
            do Screen.setColor(1);
            do Screen.drawRectangle(x, y, x+29, y+35);
            do Screen.setColor(0);
            do Screen.drawRectangle(x+1, y+1, x+28, y+34);

            if (pogodio = true) {  // ZELENO
                do Screen.setColor(1);
                do Screen.drawRectangle(x+1, y+1, x+28, y+34);
            }
            if (narancasto = true) {  // NARANCASTO
                do Screen.setColor(1);
                do Screen.drawRectangle(x+1, y+1, x+28, y+34);
                do Screen.setColor(0);
                do Screen.drawRectangle(x+4, y+4, x+25, y+31);
            }
        }
        else {
            do Screen.setColor(0);
            do Screen.drawRectangle(x, y, x+29, y+35);
        }
    
        if (pogodio = true) { do Screen.setColor(0); }
        else { do Screen.setColor(1); }

        if (slovo = 0) { return; }

        if (slovo = 95) {  // _
            do Screen.drawLine(x+9, y+29, x+20, y+29);
            do Screen.drawLine(x+9, y+28, x+20, y+28);
            return;
        }

        if ((slovo = 65) | (slovo = 97)) {  // A/a
            do Screen.drawLine(x+6, y+29, x+14, y+6);
            do Screen.drawLine(x+7, y+29, x+15, y+6);
            do Screen.drawLine(x+23, y+29, x+15, y+6);
            do Screen.drawLine(x+22, y+29, x+14, y+6);
            do Screen.drawLine(x+10, y+20, x+20, y+20);
            do Screen.drawLine(x+10, y+19, x+19, y+19);
            return;
        }

        if ((slovo = 66) | (slovo = 98)) { // B/b
            do Screen.drawLine(x+6, y+6, x+6, y+29);
            do Screen.drawLine(x+7, y+6, x+7, y+29);

            do Screen.drawLine(x+6, y+6, x+10, y+6);
            do Screen.drawLine(x+6, y+15, x+10, y+15);
            do Screen.drawLine(x+7, y+7, x+11, y+7);
            do Screen.drawLine(x+7, y+14, x+11, y+14);

            do Screen.drawLine(x+10, y+6, x+15, y+7);
            do Screen.drawLine(x+10, y+15, x+15, y+14);
            do Screen.drawLine(x+11, y+7, x+16, y+8);
            do Screen.drawLine(x+11, y+14, x+16, y+13);

            do Screen.drawLine(x+15, y+7, x+18, y+8);
            do Screen.drawLine(x+15, y+14, x+18, y+13);
            do Screen.drawLine(x+16, y+8, x+19, y+9);
            do Screen.drawLine(x+16, y+13, x+19, y+12);

            do Screen.drawLine(x+18, y+8, x+19, y+9);
            do Screen.drawLine(x+18, y+13, x+19, y+12);
            do Screen.drawLine(x+19, y+9, x+20, y+10);
            do Screen.drawLine(x+19, y+12, x+20, y+11);

            do Screen.drawLine(x+19, y+9, x+20, y+10);
            do Screen.drawLine(x+19, y+12, x+20, y+11);
            do Screen.drawLine(x+19, y+10, x+20, y+11);
            do Screen.drawLine(x+19, y+11, x+20, y+10);


            do Screen.drawLine(x+6, y+15, x+17, y+15);
            do Screen.drawLine(x+6, y+16, x+17, y+16);
            do Screen.drawLine(x+6, y+29, x+17, y+29);
            do Screen.drawLine(x+6, y+28, x+17, y+28);

            do Screen.drawLine(x+17, y+15, x+19, y+16);
            do Screen.drawLine(x+17, y+29, x+19, y+28);
            do Screen.drawLine(x+17, y+16, x+19, y+17);
            do Screen.drawLine(x+17, y+28, x+19, y+27);

            do Screen.drawLine(x+19, y+16, x+21, y+18);
