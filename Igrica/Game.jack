        }

        if ((slovo = 70) | (slovo = 102)) { // F/f
            do Screen.drawLine(x+6, y+6, x+6, y+29);
            do Screen.drawLine(x+7, y+6, x+7, y+29);
            do Screen.drawLine(x+6, y+6, x+23, y+6);
            do Screen.drawLine(x+6, y+7, x+23, y+7);
            do Screen.drawLine(x+6, y+18, x+18, y+18);
            do Screen.drawLine(x+6, y+17, x+18, y+17);
            return;
        }

        if ((slovo = 71) | (slovo = 103)) { // G/g
            do Screen.drawLine(x+23, y+6, x+15, y+6);
