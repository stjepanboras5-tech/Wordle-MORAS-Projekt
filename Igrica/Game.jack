            do Screen.drawLine(x+7, y+21, x+6, y+18);
            do Screen.drawLine(x+7, y+15, x+7, y+18);
            do Screen.drawLine(x+7, y+20, x+7, y+17);
            return;
        }

        if ((slovo = 68) | (slovo = 100)) {  // D/d
            do Screen.drawLine(x+6, y+6, x+6, y+29);
            do Screen.drawLine(x+7, y+6, x+7, y+29);

